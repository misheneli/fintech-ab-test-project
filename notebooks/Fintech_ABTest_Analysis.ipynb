import pandas as pd
import numpy as np

# Set random seed for reproducibility
np.random.seed(42)

# Generate user data
n_users = 8000
user_ids = range(1000, 1000 + n_users)
registration_dates = pd.date_range('2023-11-01', '2023-11-21', periods=n_users)
groups = np.random.choice(['A', 'B'], size=n_users, p=[0.5, 0.5]) # 50/50 split

# Simulate user characteristics
ages = np.random.normal(35, 10, n_users).astype(int)
initial_balances = np.random.exponential(1000, n_users)
# Simulate likelihood of making a deposit
made_first_deposit = np.random.binomial(1, 0.7, n_users) # 70% of users deposit
first_deposit_dates = [rd + pd.Timedelta(days=np.random.randint(0, 5)) if depo else None for rd, depo in zip(registration_dates, made_first_deposit)]

users_df = pd.DataFrame({
    'user_id': user_ids,
    'registration_date': registration_dates,
    'group_name': groups,
    'age': ages,
    'initial_balance_usd': initial_balances,
    'first_deposit_date': first_deposit_dates
})

# Generate subscriptions data (The core of the experiment)
subscriptions_data = []
for idx, user in users_df.iterrows():
    # Group A: Immediate paywall. Lower conversion.
    if user['group_name'] == 'A':
        converted = np.random.binomial(1, 0.02) # 2% conversion
        if converted:
            sub_date = user['registration_date'] + pd.Timedelta(days=np.random.randint(1, 7))
            # Simulate monthly payments for 6 months, with some churn
            for month in range(6):
                # Chance to churn increases slightly each month
                if np.random.binomial(1, 0.9 - (month * 0.05)):
                    payments.append({'user_id': user['user_id'], 'subscription_id': len(subscriptions_data) + 1, 'payment_date': sub_date + pd.DateOffset(months=month), 'payment_status': 'success'})
                else:
                    break
    # Group B: Free trial. Higher initial conversion.
    else:
        converted_trial = np.random.binomial(1, 0.05) # 5% sign up for trial
        if converted_trial:
            # Everyone gets the first 30 days free
            trial_start = user['registration_date'] + pd.Timedelta(days=np.random.randint(1, 4))
            # After trial, some users churn
            converts_to_paying = np.random.binomial(1, 0.6) # 60% convert after trial
            if converts_to_paying:
                for month in range(1, 6): # Start paying from month 2
                    if np.random.binomial(1, 0.85 - (month * 0.05)):
                        payments.append({'user_id': user['user_id'], 'subscription_id': len(subscriptions_data) + 1, 'payment_date': trial_start + pd.DateOffset(months=month), 'payment_status': 'success'})
                    else:
                        break

# Convert to DataFrame
subscriptions_df = pd.DataFrame(subscriptions_data)

# Generate trades data (optional, for commission revenue)
